APP_NAME=PhoneScope
APP_VERSION=1.0.0
DEBUG=true

UPLOAD_DIR=uploads
RESULTS_DIR=results
MAX_FILE_SIZE_MB=50
MAX_BATCH_SIZE_MB=200

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT=30/minute
UPLOAD_RATE_LIMIT=10/minute

ADMIN_SECRET_KEY=replace_with_real_secret
ADMIN_PAGE_PASSWORD=replace_with_admin_password

# 检测模型
YOLO_MODEL_PATH=D:\path\to\yolo\best.pt
YOLO_CONFIDENCE=0.7

# 旧单头分类配置（如仍需兼容可保留）
SWIN_MODEL_PATH=
SWIN_CLASSES_PATH=
SWIN_MODEL_NAME=swin_tiny_patch4_window7_224

MOBILENET_MODEL_PATH=
MOBILENET_CLASSES_PATH=
MOBILENET_MODEL_NAME=mobilenetv3_large_100

# 双头分类模型配置（推荐）
DUALHEAD_ENABLED=true
DUALHEAD_MOBILENET_RUN_DIR=D:\path\to\classification\runs\mobilenetv3
DUALHEAD_MOBILENET_BACKBONE_NAME=mobilenetv3_large_100

DUALHEAD_SWIN_RUN_DIR=D:\path\to\classification\runs\swin
DUALHEAD_SWIN_BACKBONE_NAME=swin_tiny_patch4_window7_224

USE_MOCK_SERVICES=false

MYSQL_URL=mysql+pymysql://phonescope:phonescope@localhost:3307/phonescope
FUSION_EDGE_SHRINK_RATIO=0.08
FUSION_MIN_CONFIDENCE=0.5
FUSION_MIN_AREA_RATIO=0.01
DEFAULT_FRAME_INTERVAL=30
